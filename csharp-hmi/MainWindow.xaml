<Window x:Class="SeaHmiDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEA Equipment HMI (에스이에이 장비 HMI)"
        Height="600" Width="480">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ConnectionStatusText" Grid.Row="0"
                   Text="Disconnected (연결 안됨)"
                   FontStyle="Italic" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Phase (단계): " FontWeight="Bold"/>
            <TextBlock x:Name="PhaseValueText" Text="Idle (대기)"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Temperature (온도): " FontWeight="Bold"/>
            <TextBlock x:Name="TemperatureValueText" Text="0 °C"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="Fill Level (충전율)" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid>
                <ProgressBar x:Name="FillLevelBar" Minimum="0" Maximum="100" Height="24"/>
                <TextBlock x:Name="FillLevelValueText" Text="0%"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <Border x:Name="AlarmBanner" Grid.Row="4" Background="Red" Padding="8"
                Margin="0,0,0,8" Visibility="Collapsed">
            <TextBlock Text="Alarm: Temperature exceeded (경보: 온도 초과)"
                       Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="StartButton" Content="Start (시작)" Width="100"
                    Margin="0,0,8,0" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop (정지)" Width="100"
                    Margin="0,0,8,0" Click="StopButton_Click"/>
            <Button x:Name="ResetButton" Content="Reset (초기화)" Width="100"
                    Click="ResetButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="Event Log (이벤트 로그)" FontWeight="Bold" Margin="0,0,0,4"/>
        <ListBox x:Name="EventLogListBox" Grid.Row="7"/>
    </Grid>
</Window>
