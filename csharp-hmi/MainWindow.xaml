<Window x:Class="SeaHmiDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEA Equipment HMI (에스이에이 장비 HMI)"
        Height="680" Width="520"
        Background="#1E1E24"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2B2B36" Padding="16,14">
            <Grid>
                <TextBlock Text="SEA Equipment HMI (에스이에이 장비 HMI)"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border x:Name="ConnectionPill" Background="#55606E" CornerRadius="10"
                        Padding="10,3" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ConnectionStatusText" Text="Disconnected (연결 안됨)"
                               Foreground="White" FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,20,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="120" Height="220" BorderBrush="#4A4A58" BorderThickness="2"
                    CornerRadius="6" Background="#14141A" VerticalAlignment="Top">
                <Grid ClipToBounds="True">
                    <Rectangle x:Name="TankFillRectangle" Fill="#3A7BD5" VerticalAlignment="Bottom"
                               Height="0"/>
                    <TextBlock x:Name="FillLevelValueText" Text="0%" Foreground="White"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                <TextBlock Text="PHASE (단계)" Foreground="#8A8A9A" FontSize="11" FontWeight="SemiBold"/>
                <Border x:Name="PhaseBadge" Background="#55606E" CornerRadius="4" Padding="10,6"
                        Margin="0,4,0,20" HorizontalAlignment="Left">
                    <TextBlock x:Name="PhaseValueText" Text="Idle (대기)" Foreground="White"
                               FontSize="16" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="TEMPERATURE (온도)" Foreground="#8A8A9A" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock x:Name="TemperatureValueText" Text="0 °C" Foreground="White"
                           FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <Border x:Name="AlarmBanner" Grid.Row="2" Background="#D32F2F" Padding="10"
                Margin="20,0,20,12" CornerRadius="4" Visibility="Collapsed">
            <TextBlock Text="Alarm: Temperature exceeded (경보: 온도 초과)"
                       Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="20,0,20,16">
            <Button x:Name="StartButton" Content="Start (시작)" Width="140" Height="34"
                    Margin="0,0,10,0" Click="StartButton_Click" Background="#2E9E5B"
                    Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
            <Button x:Name="StopButton" Content="Stop (정지)" Width="110" Height="34"
                    Margin="0,0,10,0" Click="StopButton_Click" Background="#C0392B"
                    Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
            <Button x:Name="ResetButton" Content="Reset (초기화)" Width="110" Height="34"
                    Click="ResetButton_Click" Background="#34495E" Foreground="White"
                    BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="EVENT LOG (이벤트 로그)" Foreground="#8A8A9A"
                   FontSize="11" FontWeight="SemiBold" Margin="20,0,20,6"/>
        <ListBox x:Name="EventLogListBox" Grid.Row="5" Margin="20,0,20,20"
                 Background="#14141A" Foreground="#D0D0D8" BorderThickness="1"
                 BorderBrush="#2B2B36" FontFamily="Consolas" FontSize="12"/>
    </Grid>
</Window>
